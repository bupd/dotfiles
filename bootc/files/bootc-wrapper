#!/bin/bash
# Wrapper that syncs ESP after bootc upgrade/switch/rollback.
# Real binary lives at /usr/bin/bootc.real
/usr/bin/bootc.real "$@"
rc=$?

case "${1:-}" in
    upgrade|switch|rollback)
        if [ $rc -eq 0 ]; then
            echo "bootc-wrapper: syncing ESP after $1..."
            /usr/bin/bootc-sync-esp
        fi
        ;;
esac

exit $rc
